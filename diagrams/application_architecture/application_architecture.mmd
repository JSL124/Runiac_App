    Basic["Basic User"]
    Premium["Premium User"]
    Admin["Platform Administrator"]
  end

  subgraph Flutter["Flutter Mobile Application"]
    direction TB

    subgraph UI["Presentation / Feature Modules"]
      direction LR
      AuthUI["Authentication &<br/>Onboarding"]
      HomeUI["Home / Dashboard"]
      RunUI["Run Tracking"]
      PlanUI["Training Plan"]
      AnalysisUI["Analysis &<br/>Post-Run Summary"]
      MotiveUI["XP / Streak /<br/>Level"]
      RouteUI["Route Sharing"]
      LeaderUI["Territorial<br/>Leaderboard"]
      NotifyUI["Reminder &<br/>Notification UI"]
      SubUI["Subscription /<br/>Entitlement"]
    end

    subgraph Logic["Application Logic / Managers"]
      direction LR
      ProfileMgr["Profile & Goal<br/>Manager"]
      RunMgr["Run Session<br/>Manager"]
      PlanMgr["Plan Manager"]
      MetricMgr["Metrics & Analysis<br/>Manager"]
      ProgressMgr["XP / Streak /<br/>Level Manager"]
      RouteMgr["Route Manager"]
      LeaderMgr["Leaderboard<br/>Manager"]
      ReminderMgr["Reminder<br/>Manager"]
      EntitlementMgr["Entitlement<br/>Manager"]
    end

    subgraph Device["Device Services"]
      direction LR
      GPS["Smartphone GPS<br/>Adapter"]
      Wearable["Optional Wearable<br/>Adapter"]
      Buffer["Local Run Buffer"]
      ShareCard["Share Card<br/>Generator"]
      PushHandler["Push Notification<br/>Handler"]
    end
  end

  subgraph Firebase["Firebase Backend / BaaS"]
    direction TB
    Auth["Firebase<br/>Authentication"]
    Firestore[("Cloud Firestore")]
    FCM["Firebase Cloud<br/>Messaging"]

    subgraph Functions["Cloud Functions Processing"]
      direction LR
      ActivityFn["Activity Validation"]
      MetricFn["Metric Derivation"]
      PlanFn["Plan Generation /<br/>Adjustment"]
      ProgressFn["XP / Streak /<br/>Level Calculation"]
      ReminderFn["Reminder Checks"]
      RouteFn["Route Privacy /<br/>Geo Indexing"]
      LeaderFn["Leaderboard<br/>Aggregation"]
      SummaryFn["AI Summary<br/>Preparation"]
      ModerationFn["Route Report /<br/>Moderation"]
    end
  end

  subgraph External["External Services"]
    direction LR
    Maps["Google Maps /<br/>Mapbox API"]
    Geo["Geocoding /<br/>Region Mapping"]
    LLM["AI / LLM Service"]
    ShareSheet["OS Share Sheet /<br/>Social Media"]
  end

