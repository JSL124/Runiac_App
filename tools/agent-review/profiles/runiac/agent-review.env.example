# Example settings for the Runiac agent-review profile.
# Copy to a local ignored env file only if you need custom paths.

REVIEW_MODE="standard"
REVIEW_ENABLED="1"
CONTEXT_PACKET_ENABLED="0"
HIGH_RISK_GUARD_ENABLED="1"
HIGH_RISK_APPROVED="0"
# REVIEW_ENABLED=1 runs Codex read-only review.
# REVIEW_ENABLED=0 explicitly skips Codex review and requires SKIP_REASON.
# CONTEXT_PACKET_ENABLED=0 preserves current runner behavior.
# CONTEXT_PACKET_ENABLED=1 calls build_context_packet.sh before Codex planning.
# HIGH_RISK_GUARD_ENABLED=1 runs deterministic high-risk checks before planning/implementation.
# HIGH_RISK_APPROVED=1 allows an explicitly approved high-risk task and requires HIGH_RISK_REASON.
# REVIEW_MODE remains only the lite|standard Codex review-depth selector.
# Do not use REVIEW_MODE=off.
# Example only; prefer explicit context class in the command:
# CONTEXT_CLASS="workflow"
# Example only; do not set a default SKIP_REASON here:
# SKIP_REASON="documentation-only change"
# Example only; do not set a default HIGH_RISK_REASON here:
# HIGH_RISK_REASON="approved high-risk dry-run validation"

PLAN_PROMPT="tools/agent-review/profiles/runiac/prompts/01_codex_create_plan.md"
CODEX_REVIEW_PROMPT="tools/agent-review/profiles/runiac/prompts/07_codex_review_plan.md"
DECISION_PROMPT="tools/agent-review/profiles/runiac/prompts/03_codex_final_review_decision.md"
IMPLEMENT_PROMPT="tools/agent-review/profiles/runiac/prompts/04_codex_implement_approved_plan.md"

PLAN_DIR="implementation/traceability/plans"
REVIEW_DIR="implementation/traceability/reviews"
DECISION_DIR="implementation/traceability/decisions"
