# Example settings for the Runiac agent-review profile.
# Copy to a local ignored env file only if you need custom paths.

REVIEW_MODE="standard"
REVIEW_ENABLED="1"
# REVIEW_ENABLED=1 runs the external Claude review step.
# REVIEW_ENABLED=0 explicitly skips external review and requires SKIP_REASON.
# REVIEW_MODE remains only the lite|standard review-depth selector.
# Do not use REVIEW_MODE=off.
# Example only; do not set a default SKIP_REASON here:
# SKIP_REASON="documentation-only change"

PLAN_PROMPT="tools/agent-review/profiles/runiac/prompts/01_codex_create_plan.md"
REVIEW_PROMPT_STANDARD="tools/agent-review/profiles/runiac/prompts/02_claude_review_plan.md"
REVIEW_PROMPT_LITE="tools/agent-review/profiles/runiac/prompts/05_claude_review_plan_lite.md"
# REVIEW_PROMPT is an explicit override. If set, it takes precedence over REVIEW_MODE.
# REVIEW_PROMPT="tools/agent-review/profiles/runiac/prompts/02_claude_review_plan.md"
DECISION_PROMPT="tools/agent-review/profiles/runiac/prompts/03_codex_final_review_decision.md"
IMPLEMENT_PROMPT="tools/agent-review/profiles/runiac/prompts/04_codex_implement_approved_plan.md"

PLAN_DIR="implementation/traceability/plans"
REVIEW_DIR="implementation/traceability/reviews"
DECISION_DIR="implementation/traceability/decisions"

CLAUDE_MAX_TURNS="12"
CLAUDE_MAX_BUDGET_USD="0.50"
