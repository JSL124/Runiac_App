rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasOnlyAllowedKeys(allowedKeys) {
      return request.resource.data.keys().hasOnly(allowedKeys);
    }

    function changesOnlyAllowedKeys(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    function backendOwnedKeys() {
      return [
        'xp',
        'totalXp',
        'totalXP',
        'divisionTier',
        'divisionKey',
        'divisionLabel',
        'levelLabel',
        'totalXpLabel',
        'nextLevelXp',
        'xpToNextLevel',
        'levelProgressPercent',
        'progressionUpdatedAt',
        'rawXpBeforeDailyCap',
        'rawXpBeforeActivityCap',
        'baseCompletionXp',
        'distanceXp',
        'durationXp',
        'planCompletionBonusXp',
        'activityCapApplied',
        'dailyCapDate',
        'dailyXpBefore',
        'dailyXpAfter',
        'dailyCapApplied',
        'previousTotalXp',
        'nextTotalXp',
        'previousLevel',
        'nextLevel',
        'previousDivisionKey',
        'nextDivisionKey',
        'previousLevelProgressPercent',
        'nextLevelProgressPercent',
        'nextLevelXpTarget',
        'nextXpToNextLevel',
        'monthlyPeriod',
        'monthlyXpBefore',
        'monthlyXpAfter',
        'plannedWorkoutBonusApplied',
        'plannedWorkoutRecorded',
        'plannedWorkoutId',
        'plannedWorkoutMatchedBy',
        'weeklyXp',
        'weeklyXP',
        'monthlyXp',
        'monthlyXP',
        'monthlyXpLabel',
        'streak',
        'streakCount',
        'lastStreakRunDate',
        'streakUpdatedAt',
        'previousStreak',
        'nextStreak',
        'previousStreakRunDate',
        'nextStreakRunDate',
        'level',
        'rank',
        'leaderboardScore',
        'scoreXp',
        'scoreXP',
        'subscriptionStatus',
        'subscriptionPrivilegeState',
        'userRole',
        'adminPrivilegeState',
        'expertPrivilegeState',
        'expertPlanPublicationState',
        'validationStatus',
        'validatedActivityContributionState',
        'countsTowardProgression',
        'backendSchedulingStatus',
        'lastScheduledAt',
        'deliveryState',
        'serverManagedTokenState',
        'moderationStatus',
        'resolutionStatus',
        'publishedAt',
        'approvedAt',
        'reviewedByAdminId',
        'publishedByAdminId'
      ];
    }

    function doesNotTouchBackendOwnedKeys() {
      return !request.resource.data.keys().hasAny(backendOwnedKeys());
    }

    function doesNotChangeBackendOwnedKeys() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(backendOwnedKeys());
    }

    function userProfileWritableKeys() {
      return [
        'displayName',
        'fullName',
        'nickname',
        'avatarInitials',
        'nicknameKey',
        'dateOfBirth',
        'ageYears',
        'weightKg',
        'locationLabel',
        'fitnessLevel',
        'goals',
        'availability',
        'planCautiousness',
        'healthSafetyReadiness',
        'updatedAt'
      ];
    }

    function affectedUserProfileKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function hasProfileField(field) {
      return field in request.resource.data;
    }

    function changesProfileField(field) {
      return affectedUserProfileKeys().hasAny([field]);
    }

    function validProfileStringField(field) {
      return !hasProfileField(field)
        || (request.resource.data[field] is string
          && request.resource.data[field].size() > 0
          && request.resource.data[field].matches('^[^\\n\\r\\t]{1,80}$'));
    }

    function validChangedProfileStringField(field) {
      return !changesProfileField(field) || validProfileStringField(field);
    }

    function validProfileShortStringField(field) {
      return !hasProfileField(field)
        || (request.resource.data[field] is string
          && request.resource.data[field].size() > 0
          && request.resource.data[field].matches('^[^\\n\\r\\t]{1,30}$'));
    }

    function validChangedProfileShortStringField(field) {
      return !changesProfileField(field) || validProfileShortStringField(field);
    }

    function validProfileInitials() {
      return !hasProfileField('avatarInitials')
        || (request.resource.data.avatarInitials is string
          && request.resource.data.avatarInitials.matches('^[A-Z]{1,3}$'));
    }

    function validProfileNicknameKey() {
      return !hasProfileField('nicknameKey')
        || (request.resource.data.nicknameKey is string
          && request.resource.data.nicknameKey.matches('^[a-z0-9][a-z0-9-]{0,29}$'));
    }

    function validChangedProfileNicknameKey() {
      return !changesProfileField('nicknameKey') || validProfileNicknameKey();
    }

    function validProfileDateOfBirth() {
      return !hasProfileField('dateOfBirth')
        || (request.resource.data.dateOfBirth is string
          && request.resource.data.dateOfBirth.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$'));
    }

    function validChangedProfileDateOfBirth() {
      return !changesProfileField('dateOfBirth') || validProfileDateOfBirth();
    }

    function validProfileLocationLabel() {
      return !hasProfileField('locationLabel')
        || (request.resource.data.locationLabel is string
          && request.resource.data.locationLabel.matches('^[^\\n\\r\\t]{1,68}, Singapore$'));
    }

    function validChangedProfileLocationLabel() {
      return !changesProfileField('locationLabel') || validProfileLocationLabel();
    }

    function validProfileNicknameClaimAfter() {
      return hasProfileField('nicknameKey')
        && existsAfter(/databases/$(database)/documents/nicknameClaims/$(request.resource.data.nicknameKey))
        && getAfter(/databases/$(database)/documents/nicknameClaims/$(request.resource.data.nicknameKey)).data.ownerUid == request.auth.uid
        && getAfter(/databases/$(database)/documents/nicknameClaims/$(request.resource.data.nicknameKey)).data.nicknameKey == request.resource.data.nicknameKey;
    }

    function validProfileNicknameClaimForChangedNickname() {
      return !(changesProfileField('nickname')
          || changesProfileField('nicknameKey'))
        || validProfileNicknameClaimAfter();
    }

    function validChangedProfileInitials() {
      return !changesProfileField('avatarInitials') || validProfileInitials();
    }

    function validProfileAgeYears() {
      return !hasProfileField('ageYears')
        || (request.resource.data.ageYears is int
          && request.resource.data.ageYears >= 13
          && request.resource.data.ageYears <= 100);
    }

    function validChangedProfileAgeYears() {
      return !changesProfileField('ageYears') || validProfileAgeYears();
    }

    function validProfileWeightKg() {
      return !hasProfileField('weightKg')
        || ((request.resource.data.weightKg is int
          || request.resource.data.weightKg is float)
          && request.resource.data.weightKg >= 30
          && request.resource.data.weightKg <= 250);
    }

    function validChangedProfileWeightKg() {
      return !changesProfileField('weightKg') || validProfileWeightKg();
    }

    function validProfileUpdatedAt() {
      return !hasProfileField('updatedAt')
        || request.resource.data.updatedAt is int
        || request.resource.data.updatedAt is timestamp;
    }

    function validChangedProfileUpdatedAt() {
      return !changesProfileField('updatedAt') || validProfileUpdatedAt();
    }

    function validProfileAvailability() {
      return !hasProfileField('availability')
        || (request.resource.data.availability is map
          && request.resource.data.availability.keys().hasOnly([
            'weeklySessions',
            'preferredDays',
            'preferredTime',
            'sessionLengthMinutes'
          ])
          && request.resource.data.availability.weeklySessions is string
          && request.resource.data.availability.preferredDays is list
          && request.resource.data.availability.preferredTime is string
          && request.resource.data.availability.sessionLengthMinutes is string);
    }

    function validChangedProfileAvailability() {
      return !changesProfileField('availability') || validProfileAvailability();
    }

    function validProfileHealthSafetyReadiness() {
      return !hasProfileField('healthSafetyReadiness')
        || (request.resource.data.healthSafetyReadiness is map
          && request.resource.data.healthSafetyReadiness.keys().hasOnly([
            'comfort',
            'activitySymptoms',
            'recentRunningConsistency',
            'currentWeeklyRunFrequency',
            'continuousRunCapacity',
            'runningPlace',
            'motivationStyle'
          ])
          && request.resource.data.healthSafetyReadiness.comfort is string
          && request.resource.data.healthSafetyReadiness.activitySymptoms is list
          && request.resource.data.healthSafetyReadiness.recentRunningConsistency is string
          && request.resource.data.healthSafetyReadiness.currentWeeklyRunFrequency is string
          && request.resource.data.healthSafetyReadiness.continuousRunCapacity is string
          && request.resource.data.healthSafetyReadiness.runningPlace is string
          && request.resource.data.healthSafetyReadiness.motivationStyle is string);
    }

    function validChangedProfileHealthSafetyReadiness() {
      return !changesProfileField('healthSafetyReadiness')
        || validProfileHealthSafetyReadiness();
    }

    function validProfileGoals() {
      return !hasProfileField('goals') || request.resource.data.goals is list;
    }

    function validChangedProfileGoals() {
      return !changesProfileField('goals') || validProfileGoals();
    }

    function validUserProfileCreateData() {
      return hasOnlyAllowedKeys(userProfileWritableKeys())
        && validProfileStringField('displayName')
        && validProfileStringField('fullName')
        && validProfileShortStringField('nickname')
        && validProfileInitials()
        && validProfileNicknameKey()
        && validProfileDateOfBirth()
        && validProfileAgeYears()
        && validProfileWeightKg()
        && validProfileLocationLabel()
        && validProfileStringField('fitnessLevel')
        && validProfileGoals()
        && validProfileAvailability()
        && validProfileStringField('planCautiousness')
        && validProfileHealthSafetyReadiness()
        && validProfileUpdatedAt()
        && validProfileNicknameClaimAfter();
    }

    function validUserProfileUpdateData() {
      return changesOnlyAllowedKeys(userProfileWritableKeys())
        && validChangedProfileStringField('displayName')
        && validChangedProfileStringField('fullName')
        && validChangedProfileShortStringField('nickname')
        && validChangedProfileInitials()
        && validChangedProfileNicknameKey()
        && validChangedProfileDateOfBirth()
        && validChangedProfileAgeYears()
        && validChangedProfileWeightKg()
        && validChangedProfileLocationLabel()
        && validChangedProfileStringField('fitnessLevel')
        && validChangedProfileGoals()
        && validChangedProfileAvailability()
        && validChangedProfileStringField('planCautiousness')
        && validChangedProfileHealthSafetyReadiness()
        && validChangedProfileUpdatedAt()
        && validProfileNicknameClaimForChangedNickname();
    }

    function validNicknameClaimData(nicknameKey) {
      return hasOnlyAllowedKeys([
          'ownerUid',
          'nickname',
          'nicknameKey',
          'updatedAt'
        ])
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.nicknameKey == nicknameKey
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() > 0
        && request.resource.data.nickname.matches('^[^\\n\\r\\t]{1,30}$')
        && request.resource.data.nicknameKey.matches('^[a-z0-9][a-z0-9-]{0,29}$')
        && validProfileUpdatedAt();
    }

    function generatedPlanWritableKeys() {
      return [
        'planId',
        'planKind',
        'title',
        'subtitle',
        'sourceLabel',
        'startsOnDate',
        'durationWeeks',
        'safetyBand',
        'templateKind',
        'family',
        'familyCategory',
        'familyReason',
        'supportStyleLabel',
        'weeklyFrequencyLabel',
        'preferredScheduleLabel',
        'sessionDurationLabel',
        'safetyNote',
        'clientDisplayStatus',
        'weeks',
        'createdAt',
        'updatedAt'
      ];
    }

    function generatedPlanWeekWritableKeys() {
      return ['weekNumber', 'title', 'focus', 'workouts'];
    }

    function generatedPlanWorkoutWritableKeys() {
      return [
        'dayLabel',
        'title',
        'durationMinutes',
        'kind',
        'intensity',
        'description',
        'steps',
        'supportiveNote',
        'detail',
        'scheduleTimeLabel'
      ];
    }

    function generatedPlanDetailWritableKeys() {
      return ['metrics', 'breakdown', 'effortGuide', 'coachNotes'];
    }

    function validGeneratedPlanStringList(values, maxSize) {
      return values is list
        && values.size() <= maxSize
        && (values.size() < 1 || values[0] is string)
        && (values.size() < 2 || values[1] is string)
        && (values.size() < 3 || values[2] is string);
    }

    function validGeneratedPlanWeeks(weeks) {
      return weeks is list
        && weeks.size() > 0
        && weeks.size() <= 8
        && validGeneratedPlanWeek(weeks[0]);
    }

    function validGeneratedPlanWeek(week) {
      return week is map
        && week.keys().hasOnly(generatedPlanWeekWritableKeys())
        && week.weekNumber is int
        && week.title is string
        && week.focus is string
        && validGeneratedPlanWorkouts(week.workouts);
    }

    function validGeneratedPlanWorkouts(workouts) {
      return workouts is list
        && workouts.size() <= 7
        && (workouts.size() < 1 || validGeneratedPlanWorkout(workouts[0]));
    }

    function validGeneratedPlanWorkout(workout) {
      return workout is map
        && workout.keys().hasOnly(generatedPlanWorkoutWritableKeys())
        && workout.dayLabel is string
        && workout.title is string
        && workout.durationMinutes is int
        && workout.kind is string
        && workout.intensity is string
        && workout.description is string
        && validGeneratedPlanStringList(workout.steps, 3)
        && workout.supportiveNote is string
        && validGeneratedPlanDetail(workout.detail)
        && (!workout.keys().hasAny(['scheduleTimeLabel'])
          || workout.scheduleTimeLabel is string);
    }

    function validGeneratedPlanDetail(detail) {
      return detail is map
        && detail.keys().hasOnly(generatedPlanDetailWritableKeys())
        && validGeneratedPlanMetrics(detail.metrics)
        && validGeneratedPlanBreakdown(detail.breakdown)
        && detail.effortGuide is string
        && validGeneratedPlanStringList(detail.coachNotes, 3);
    }

    function validGeneratedPlanMetrics(metrics) {
      return metrics is list
        && metrics.size() <= 4;
    }

    function validGeneratedPlanBreakdown(breakdown) {
      return breakdown is list
        && breakdown.size() <= 8;
    }

    function validGeneratedPlanData(uid) {
      return hasOnlyAllowedKeys(generatedPlanWritableKeys())
        && request.resource.data.planId is string
        && request.resource.data.planKind == 'onboardingBased'
        && request.resource.data.title is string
        && request.resource.data.subtitle is string
        && request.resource.data.sourceLabel is string
        && (!request.resource.data.keys().hasAny(['startsOnDate'])
          || request.resource.data.startsOnDate is string)
        && request.resource.data.durationWeeks is int
        && request.resource.data.safetyBand is string
        && request.resource.data.templateKind is string
        && validGeneratedPlanFamilyFields()
        && request.resource.data.familyReason is string
        && request.resource.data.supportStyleLabel is string
        && request.resource.data.weeklyFrequencyLabel is string
        && request.resource.data.preferredScheduleLabel is string
        && request.resource.data.sessionDurationLabel is string
        && request.resource.data.safetyNote is string
        && request.resource.data.clientDisplayStatus in [
          'generatedPlan',
          'safetyReadiness'
        ]
        && validGeneratedPlanWeeksForStatus()
        && validGeneratedPlanTimestamp('createdAt')
        && validGeneratedPlanTimestamp('updatedAt')
        && validProfileUpdatedAt()
        && doesNotTouchBackendOwnedKeys();
    }

    function validGeneratedPlanTimestamp(fieldName) {
      return !request.resource.data.keys().hasAny([fieldName])
        || request.resource.data[fieldName] is int
        || request.resource.data[fieldName] is timestamp
        || request.resource.data[fieldName] is string;
    }

    function validGeneratedPlanFamilyFields() {
      return (request.resource.data.clientDisplayStatus == 'generatedPlan'
          && request.resource.data.family is string
          && request.resource.data.familyCategory is string)
        || (request.resource.data.clientDisplayStatus == 'safetyReadiness'
          && request.resource.data.family == null
          && request.resource.data.familyCategory == null);
    }

    function validGeneratedPlanWeeksForStatus() {
      return (request.resource.data.clientDisplayStatus == 'generatedPlan'
          && validGeneratedPlanWeeks(request.resource.data.weeks))
        || (request.resource.data.clientDisplayStatus == 'safetyReadiness'
          && request.resource.data.weeks is list
          && request.resource.data.weeks.size() == 0);
    }

    function isPremiumUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscriptionStatus == 'premium';
    }

    function isPublishedExpertPlan(planId) {
      return exists(/databases/$(database)/documents/expertPlans/$(planId))
        && get(/databases/$(database)/documents/expertPlans/$(planId)).data.status == 'published';
    }

    function hasTrustedFriendship(authorUid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(authorUid))
        && exists(/databases/$(database)/documents/users/$(authorUid)/friends/$(request.auth.uid));
    }

    function hasNoDirectionalBlock(authorUid) {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid)/blockedUsers/$(authorUid))
        && !exists(/databases/$(database)/documents/users/$(authorUid)/blockedUsers/$(request.auth.uid));
    }

    function canReadFeedAuthor(authorUid) {
      return isSignedIn()
        && hasNoDirectionalBlock(authorUid)
        && (authorUid == request.auth.uid || hasTrustedFriendship(authorUid));
    }

    function canReadFeedPost(postId) {
      return exists(/databases/$(database)/documents/feedPosts/$(postId))
        && get(/databases/$(database)/documents/feedPosts/$(postId)).data.status == 'published'
        && canReadFeedAuthor(
          get(/databases/$(database)/documents/feedPosts/$(postId)).data.authorUid
        );
    }

    function validFeedCommentBody(body) {
      return body is string
        && body.size() >= 1
        && body.size() <= 500
        && body.matches('^[^\\s](.*[^\\s])?$');
    }

    function matchesCallerProfileSnapshot() {
      return exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
        && request.resource.data.authorDisplayName
          == get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.displayName
        && request.resource.data.authorAvatarInitials
          == get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.avatarInitials
        && (!request.resource.data.keys().hasAny(['authorLevelLabel'])
          || request.resource.data.authorLevelLabel
            == get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.levelLabel);
    }

    function validFeedCommentCreate(postId) {
      return canReadFeedPost(postId)
        && hasOnlyAllowedKeys([
          'authorUid',
          'authorDisplayName',
          'authorAvatarInitials',
          'authorLevelLabel',
          'body',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && validFeedCommentBody(request.resource.data.body)
        && matchesCallerProfileSnapshot();
    }

    function validFeedCommentUpdate(postId) {
      return canReadFeedPost(postId)
        && resource.data.authorUid == request.auth.uid
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.authorDisplayName == resource.data.authorDisplayName
        && request.resource.data.authorAvatarInitials == resource.data.authorAvatarInitials
        && request.resource.data.authorLevelLabel == resource.data.authorLevelLabel
        && request.resource.data.createdAt == resource.data.createdAt
        && changesOnlyAllowedKeys(['body', 'updatedAt'])
        && request.resource.data.updatedAt == request.time
        && validFeedCommentBody(request.resource.data.body);
    }

    function notificationInboxMutableKeys() {
      return ['readAt', 'deletedAt', 'updatedAt'];
    }

    function notificationInboxClientManagedKeys() {
      return [
        'ownerUid',
        'clientManaged',
        'title',
        'body',
        'createdAt',
        'data',
        'readAt',
        'deletedAt',
        'updatedAt'
      ];
    }

    function validNotificationInboxClientManagedData(uid) {
      return request.resource.data.ownerUid == uid
        && request.resource.data.clientManaged == true
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 500
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (!('data' in request.resource.data) || request.resource.data.data is map)
        && (!('readAt' in request.resource.data) || request.resource.data.readAt is timestamp)
        && (!('deletedAt' in request.resource.data) || request.resource.data.deletedAt is timestamp)
        && hasOnlyAllowedKeys(notificationInboxClientManagedKeys())
        && doesNotTouchBackendOwnedKeys();
    }

    function validNotificationInboxMutableValues() {
      return validNotificationInboxMutableValue('readAt')
        && validNotificationInboxMutableValue('deletedAt')
        && validNotificationInboxMutableValue('updatedAt');
    }

    function validNotificationInboxMutableValue(field) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([field])
        || request.resource.data[field] is timestamp;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update, delete: if false;

      match /friends/{friendUid} {
        allow get: if isOwner(uid);
        allow list: if isOwner(uid)
          && request.query.limit != null
          && request.query.limit <= 30;
        allow create, update, delete: if false;
      }

      match /blockedUsers/{blockedUid} {
        allow get: if isOwner(uid);
        allow list: if isOwner(uid)
          && request.query.limit != null
          && request.query.limit <= 30;
        allow create, update, delete: if false;
      }

      match /hiddenFeedPosts/{postId} {
        allow get: if isOwner(uid);
        allow list: if isOwner(uid)
          && request.query.limit != null
          && request.query.limit <= 30;
        allow create, update, delete: if false;
      }
    }

    match /userProfiles/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && validUserProfileCreateData()
        && doesNotTouchBackendOwnedKeys();
      allow update: if isOwner(uid)
        && validUserProfileUpdateData()
        && doesNotChangeBackendOwnedKeys();
      allow delete: if false;
    }

    match /nicknameClaims/{nicknameKey} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn()
        && validNicknameClaimData(nicknameKey);
      allow update: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && validNicknameClaimData(nicknameKey);
      allow delete: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    match /generatedPlans/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && validGeneratedPlanData(uid);
      allow update: if isOwner(uid)
        && changesOnlyAllowedKeys(generatedPlanWritableKeys())
        && validGeneratedPlanData(uid)
        && doesNotChangeBackendOwnedKeys();
      allow delete: if false;
    }

    match /planProgress/{uid} {
      allow get: if isOwner(uid);
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /adaptivePlanEstimates/{uid} {
      allow get: if isOwner(uid);
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /agentGuidanceDaily/{document} {
      allow read, write: if false;
    }

    match /activities/{activityId} {
      allow read: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && hasOnlyAllowedKeys([
          'ownerUid',
          'status',
          'source',
          'activityType',
          'startedAt',
          'endedAt',
          'durationSeconds',
          'distanceMeters',
          'averagePaceSecondsPerKm',
          'routePrivacy',
          'createdAt',
          'updatedAt'
        ])
        && doesNotTouchBackendOwnedKeys();
      allow update: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status == 'pending'
        && changesOnlyAllowedKeys([
          'ownerUid',
          'status',
          'source',
          'activityType',
          'startedAt',
          'endedAt',
          'durationSeconds',
          'distanceMeters',
          'averagePaceSecondsPerKm',
          'routePrivacy',
          'createdAt',
          'updatedAt'
        ])
        && doesNotTouchBackendOwnedKeys()
        && doesNotChangeBackendOwnedKeys();
      allow delete: if false;
    }

    match /feedPosts/{postId} {
      allow get: if resource.data.status == 'published'
        && canReadFeedAuthor(resource.data.authorUid);
      allow list: if request.query.limit != null
        && request.query.limit <= 20
        && resource.data.status == 'published'
        && canReadFeedAuthor(resource.data.authorUid);
      allow create, update, delete: if false;

      match /likes/{uid} {
        allow get: if canReadFeedPost(postId);
        allow list: if false;
        allow create: if canReadFeedPost(postId)
          && uid == request.auth.uid
          && hasOnlyAllowedKeys(['userUid', 'createdAt'])
          && request.resource.data.userUid == request.auth.uid
          && request.resource.data.createdAt == request.time;
        allow update: if false;
        allow delete: if canReadFeedPost(postId)
          && uid == request.auth.uid
          && resource.data.userUid == request.auth.uid;
      }

      match /comments/{commentId} {
        allow get: if canReadFeedPost(postId);
        allow list: if canReadFeedPost(postId)
          && request.query.limit != null
          && request.query.limit <= 20;
        allow create: if validFeedCommentCreate(postId);
        allow update: if validFeedCommentUpdate(postId);
        allow delete: if canReadFeedPost(postId)
          && resource.data.authorUid == request.auth.uid;
      }
    }

    match /runSummaries/{summaryId} {
      allow get: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow list: if isSignedIn()
        && request.query.limit != null
        && request.query.limit <= 30
        && resource.data.ownerUid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /progressionEvents/{eventId} {
      allow read: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /leaderboardSnapshots/{snapshotId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /leaderboardPeriods/{periodId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /leaderboardCurrentViews/{uid} {
      allow read: if isSignedIn() && uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /leaderboardUserRanks/{rankId} {
      allow read: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /leaderboardContributions/{contributionId} {
      allow read, create, update, delete: if false;
    }

    match /leaderboardAggregationLocks/{snapshotId} {
      allow read, create, update, delete: if false;
    }

    match /leaderboardSeedRuns/{runId} {
      allow read, create, update, delete: if false;
    }

    match /sharedRoutes/{routeId} {
      allow read: if isSignedIn()
        && (resource.data.ownerUid == request.auth.uid
          || resource.data.visibilityStatus == 'published');
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && hasOnlyAllowedKeys([
          'ownerUid',
          'title',
          'description',
          'distanceMeters',
          'estimatedDurationSeconds',
          'difficulty',
          'regionLabel',
          'visibilityStatus',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.visibilityStatus in ['private', 'draft']
        && doesNotTouchBackendOwnedKeys();
      allow update, delete: if false;
    }

    match /expertPlans/{planId} {
      allow read: if isPremiumUser() && resource.data.status == 'published';
      allow create, update, delete: if false;
    }

    match /planEnrollments/{enrollmentId} {
      allow read: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn()
        && isPremiumUser()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && isPublishedExpertPlan(request.resource.data.planId)
        && hasOnlyAllowedKeys([
          'ownerUid',
          'planId',
          'planType',
          'status',
          'requestedAt'
        ])
        && doesNotTouchBackendOwnedKeys();
      allow update, delete: if false;
    }

    match /reports/{reportId} {
      allow read: if isSignedIn() && resource.data.reporterUid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.targetType != 'feedPost'
        && hasOnlyAllowedKeys([
          'reporterUid',
          'targetType',
          'targetId',
          'reason',
          'description',
          'createdAt'
        ])
        && doesNotTouchBackendOwnedKeys();
      allow update, delete: if false;
    }

    match /notificationDevices/{uid}/tokens/{tokenFingerprint} {
      allow read, write: if false;
    }

    match /notificationDeliveries/{deliveryId} {
      allow read, write: if false;
    }

    match /notificationInbox/{uid}/items/{notificationId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && validNotificationInboxClientManagedData(uid);
      allow update: if isOwner(uid)
        && (
          (
            resource.data.ownerUid == uid
            && request.resource.data.ownerUid == uid
            && changesOnlyAllowedKeys(notificationInboxMutableKeys())
            && validNotificationInboxMutableValues()
          )
          || (
            resource.data.ownerUid == uid
            && resource.data.clientManaged == true
            && validNotificationInboxClientManagedData(uid)
          )
        );
      allow delete: if false;
    }

    match /notificationPreferences/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.ownerUid == uid
        && hasOnlyAllowedKeys([
          'ownerUid',
          'runReminderEnabled',
          'restReminderEnabled',
          'streakRiskEnabled',
          'reminderTime',
          'quietHoursStart',
          'quietHoursEnd',
          'updatedAt'
        ])
        && doesNotTouchBackendOwnedKeys();
      allow update: if isOwner(uid)
        && request.resource.data.ownerUid == uid
        && changesOnlyAllowedKeys([
          'ownerUid',
          'runReminderEnabled',
          'restReminderEnabled',
          'streakRiskEnabled',
          'reminderTime',
          'quietHoursStart',
          'quietHoursEnd',
          'updatedAt'
        ])
        && doesNotChangeBackendOwnedKeys();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
