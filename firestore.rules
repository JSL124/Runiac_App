rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasOnlyAllowedKeys(allowedKeys) {
      return request.resource.data.keys().hasOnly(allowedKeys);
    }

    function changesOnlyAllowedKeys(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    function backendOwnedKeys() {
      return [
        'xp',
        'totalXp',
        'totalXP',
        'weeklyXp',
        'weeklyXP',
        'monthlyXp',
        'monthlyXP',
        'streak',
        'streakCount',
        'level',
        'rank',
        'leaderboardScore',
        'scoreXp',
        'scoreXP',
        'subscriptionStatus',
        'subscriptionPrivilegeState',
        'userRole',
        'adminPrivilegeState',
        'expertPrivilegeState',
        'expertPlanPublicationState',
        'validationStatus',
        'validatedActivityContributionState',
        'countsTowardProgression',
        'backendSchedulingStatus',
        'lastScheduledAt',
        'deliveryState',
        'serverManagedTokenState',
        'moderationStatus',
        'resolutionStatus',
        'publishedAt',
        'approvedAt',
        'reviewedByAdminId',
        'publishedByAdminId'
      ];
    }

    function doesNotTouchBackendOwnedKeys() {
      return !request.resource.data.keys().hasAny(backendOwnedKeys());
    }

    function doesNotChangeBackendOwnedKeys() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(backendOwnedKeys());
    }

    function userProfileWritableKeys() {
      return [
        'displayName',
        'fullName',
        'nickname',
        'avatarInitials',
        'ageYears',
        'weightKg',
        'locationLabel',
        'fitnessLevel',
        'goals',
        'availability',
        'planCautiousness',
        'healthSafetyReadiness',
        'updatedAt'
      ];
    }

    function affectedUserProfileKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function hasProfileField(field) {
      return field in request.resource.data;
    }

    function changesProfileField(field) {
      return affectedUserProfileKeys().hasAny([field]);
    }

    function validProfileStringField(field) {
      return !hasProfileField(field)
        || (request.resource.data[field] is string
          && request.resource.data[field].size() > 0
          && request.resource.data[field].matches('^[^\\n\\r\\t]{1,80}$'));
    }

    function validChangedProfileStringField(field) {
      return !changesProfileField(field) || validProfileStringField(field);
    }

    function validProfileShortStringField(field) {
      return !hasProfileField(field)
        || (request.resource.data[field] is string
          && request.resource.data[field].size() > 0
          && request.resource.data[field].matches('^[^\\n\\r\\t]{1,30}$'));
    }

    function validChangedProfileShortStringField(field) {
      return !changesProfileField(field) || validProfileShortStringField(field);
    }

    function validProfileInitials() {
      return !hasProfileField('avatarInitials')
        || (request.resource.data.avatarInitials is string
          && request.resource.data.avatarInitials.matches('^[A-Z]{1,3}$'));
    }

    function validChangedProfileInitials() {
      return !changesProfileField('avatarInitials') || validProfileInitials();
    }

    function validProfileAgeYears() {
      return !hasProfileField('ageYears')
        || (request.resource.data.ageYears is int
          && request.resource.data.ageYears >= 13
          && request.resource.data.ageYears <= 100);
    }

    function validChangedProfileAgeYears() {
      return !changesProfileField('ageYears') || validProfileAgeYears();
    }

    function validProfileWeightKg() {
      return !hasProfileField('weightKg')
        || ((request.resource.data.weightKg is int
          || request.resource.data.weightKg is float)
          && request.resource.data.weightKg >= 30
          && request.resource.data.weightKg <= 250);
    }

    function validChangedProfileWeightKg() {
      return !changesProfileField('weightKg') || validProfileWeightKg();
    }

    function validProfileUpdatedAt() {
      return !hasProfileField('updatedAt')
        || request.resource.data.updatedAt is int
        || request.resource.data.updatedAt is timestamp;
    }

    function validChangedProfileUpdatedAt() {
      return !changesProfileField('updatedAt') || validProfileUpdatedAt();
    }

    function validProfileAvailability() {
      return !hasProfileField('availability')
        || (request.resource.data.availability is map
          && request.resource.data.availability.keys().hasOnly([
            'weeklySessions',
            'preferredDays',
            'preferredTime',
            'sessionLengthMinutes'
          ])
          && request.resource.data.availability.weeklySessions is string
          && request.resource.data.availability.preferredDays is list
          && request.resource.data.availability.preferredTime is string
          && request.resource.data.availability.sessionLengthMinutes is string);
    }

    function validChangedProfileAvailability() {
      return !changesProfileField('availability') || validProfileAvailability();
    }

    function validProfileHealthSafetyReadiness() {
      return !hasProfileField('healthSafetyReadiness')
        || (request.resource.data.healthSafetyReadiness is map
          && request.resource.data.healthSafetyReadiness.keys().hasOnly([
            'comfort',
            'activitySymptoms',
            'recentRunningConsistency',
            'currentWeeklyRunFrequency',
            'continuousRunCapacity',
            'runningPlace',
            'motivationStyle'
          ])
          && request.resource.data.healthSafetyReadiness.comfort is string
          && request.resource.data.healthSafetyReadiness.activitySymptoms is list
          && request.resource.data.healthSafetyReadiness.recentRunningConsistency is string
          && request.resource.data.healthSafetyReadiness.currentWeeklyRunFrequency is string
          && request.resource.data.healthSafetyReadiness.continuousRunCapacity is string
          && request.resource.data.healthSafetyReadiness.runningPlace is string
          && request.resource.data.healthSafetyReadiness.motivationStyle is string);
    }

    function validChangedProfileHealthSafetyReadiness() {
      return !changesProfileField('healthSafetyReadiness')
        || validProfileHealthSafetyReadiness();
    }

    function validProfileGoals() {
      return !hasProfileField('goals') || request.resource.data.goals is list;
    }

    function validChangedProfileGoals() {
      return !changesProfileField('goals') || validProfileGoals();
    }

    function validUserProfileCreateData() {
      return hasOnlyAllowedKeys(userProfileWritableKeys())
        && validProfileStringField('displayName')
        && validProfileStringField('fullName')
        && validProfileShortStringField('nickname')
        && validProfileInitials()
        && validProfileAgeYears()
        && validProfileWeightKg()
        && validProfileStringField('locationLabel')
        && validProfileStringField('fitnessLevel')
        && validProfileGoals()
        && validProfileAvailability()
        && validProfileStringField('planCautiousness')
        && validProfileHealthSafetyReadiness()
        && validProfileUpdatedAt();
    }

    function validUserProfileUpdateData() {
      return changesOnlyAllowedKeys(userProfileWritableKeys())
        && validChangedProfileStringField('displayName')
        && validChangedProfileStringField('fullName')
        && validChangedProfileShortStringField('nickname')
        && validChangedProfileInitials()
        && validChangedProfileAgeYears()
        && validChangedProfileWeightKg()
        && validChangedProfileStringField('locationLabel')
        && validChangedProfileStringField('fitnessLevel')
        && validChangedProfileGoals()
        && validChangedProfileAvailability()
        && validChangedProfileStringField('planCautiousness')
        && validChangedProfileHealthSafetyReadiness()
        && validChangedProfileUpdatedAt();
    }

    function isPremiumUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscriptionStatus == 'premium';
    }

    function isPublishedExpertPlan(planId) {
      return exists(/databases/$(database)/documents/expertPlans/$(planId))
        && get(/databases/$(database)/documents/expertPlans/$(planId)).data.status == 'published';
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update, delete: if false;
    }

    match /userProfiles/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && validUserProfileCreateData()
        && doesNotTouchBackendOwnedKeys();
      allow update: if isOwner(uid)
        && validUserProfileUpdateData()
        && doesNotChangeBackendOwnedKeys();
      allow delete: if false;
    }

    match /activities/{activityId} {
      allow read: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && hasOnlyAllowedKeys([
          'ownerUid',
          'status',
          'source',
          'activityType',
          'startedAt',
          'endedAt',
          'durationSeconds',
          'distanceMeters',
          'averagePaceSecondsPerKm',
          'routePrivacy',
          'createdAt',
          'updatedAt'
        ])
        && doesNotTouchBackendOwnedKeys();
      allow update: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status == 'pending'
        && changesOnlyAllowedKeys([
          'ownerUid',
          'status',
          'source',
          'activityType',
          'startedAt',
          'endedAt',
          'durationSeconds',
          'distanceMeters',
          'averagePaceSecondsPerKm',
          'routePrivacy',
          'createdAt',
          'updatedAt'
        ])
        && doesNotTouchBackendOwnedKeys()
        && doesNotChangeBackendOwnedKeys();
      allow delete: if false;
    }

    match /runSummaries/{summaryId} {
      allow read: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /progressionEvents/{eventId} {
      allow read: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /leaderboardSnapshots/{snapshotId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /sharedRoutes/{routeId} {
      allow read: if isSignedIn()
        && (resource.data.ownerUid == request.auth.uid
          || resource.data.visibilityStatus == 'published');
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && hasOnlyAllowedKeys([
          'ownerUid',
          'title',
          'description',
          'distanceMeters',
          'estimatedDurationSeconds',
          'difficulty',
          'regionLabel',
          'visibilityStatus',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.visibilityStatus in ['private', 'draft']
        && doesNotTouchBackendOwnedKeys();
      allow update, delete: if false;
    }

    match /expertPlans/{planId} {
      allow read: if isPremiumUser() && resource.data.status == 'published';
      allow create, update, delete: if false;
    }

    match /planEnrollments/{enrollmentId} {
      allow read: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn()
        && isPremiumUser()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && isPublishedExpertPlan(request.resource.data.planId)
        && hasOnlyAllowedKeys([
          'ownerUid',
          'planId',
          'planType',
          'status',
          'requestedAt'
        ])
        && doesNotTouchBackendOwnedKeys();
      allow update, delete: if false;
    }

    match /reports/{reportId} {
      allow read: if isSignedIn() && resource.data.reporterUid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid
        && hasOnlyAllowedKeys([
          'reporterUid',
          'targetType',
          'targetId',
          'reason',
          'description',
          'createdAt'
        ])
        && doesNotTouchBackendOwnedKeys();
      allow update, delete: if false;
    }

    match /notificationPreferences/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.ownerUid == uid
        && hasOnlyAllowedKeys([
          'ownerUid',
          'runReminderEnabled',
          'restReminderEnabled',
          'streakRiskEnabled',
          'reminderTime',
          'quietHoursStart',
          'quietHoursEnd',
          'updatedAt'
        ])
        && doesNotTouchBackendOwnedKeys();
      allow update: if isOwner(uid)
        && request.resource.data.ownerUid == uid
        && changesOnlyAllowedKeys([
          'ownerUid',
          'runReminderEnabled',
          'restReminderEnabled',
          'streakRiskEnabled',
          'reminderTime',
          'quietHoursStart',
          'quietHoursEnd',
          'updatedAt'
        ])
        && doesNotChangeBackendOwnedKeys();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
